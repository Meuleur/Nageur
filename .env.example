# --- Supabase (D3) ---
# One Supabase project per environment (dev / staging / production).
# Real values live in .env.local (dev) and in Vercel environment variables —
# never committed (D3). Copy this file to .env.local to get started.

# Public — safe to expose to the browser (RLS is the security barrier).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — bypasses RLS. NEVER prefix with NEXT_PUBLIC_, never expose.
SUPABASE_SERVICE_ROLE_KEY=

# --- Authentification & e-mails (CH2 / C1) ---
# Secret HMAC serveur : hachage des codes OTP, signature des jetons de
# transition (2FA en attente, réinitialisation), clés de rate limiting.
# ≥ 32 caractères aléatoires (ex. `openssl rand -hex 32`). Server only.
AUTH_SECRET=

# Resend (ADR-013) — envoi des e-mails applicatifs (code OTP 2FA, notifications
# métier CH7) par le serveur. En production, configurer AUSSI le SMTP Resend
# dans Supabase Auth pour les e-mails de vérification/réinitialisation (voir
# supabase/config.toml).
RESEND_API_KEY=
EMAIL_FROM="App Natation <no-reply@example.com>"

# Pilote e-mail : "resend" (production) ou "mailpit" (dev local / E2E — les
# e-mails applicatifs partent dans la boîte Mailpit de `supabase start`,
# aucun envoi réel ; RESEND_API_KEY est alors inutile).
EMAIL_DRIVER=resend
# MAILPIT_URL=http://127.0.0.1:54324

# URL publique de l'application — liens d'action des e-mails métier (CH7/C3).
# Défaut : http://localhost:3000 (dev / E2E). En production : l'URL Vercel.
# APP_URL=http://localhost:3000

# --- Génération IA (CH4/CH5 / C2) ---
# Pilote LLM : "fournisseur" (défaut — appelle le fournisseur actif, clé via
# Vault) ou "simule" (dev local sans clé réelle / E2E : séance déterministe,
# aucun appel réseau). Jamais "simule" en production. Les tests Playwright
# démarrent leur serveur avec LLM_DRIVER=simule (playwright.config.ts).
# LLM_DRIVER=simule
