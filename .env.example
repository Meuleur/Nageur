# --- Supabase (D3) ---
# One Supabase project per environment (dev / staging / production).
# Real values live in .env.local (dev) and in Vercel environment variables —
# never committed (D3). Copy this file to .env.local to get started.

# Public — safe to expose to the browser (RLS is the security barrier).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — bypasses RLS. NEVER prefix with NEXT_PUBLIC_, never expose.
SUPABASE_SERVICE_ROLE_KEY=
